#!/usr/bin/env sh
branch=$(git symbolic-ref --short HEAD)
if [ "$branch" = "main" ]; then
  echo "ERROR: Direct push to main is forbidden. Use a feature branch + PR."
  echo "If you really need to bypass (emergency only), use: git push --no-verify"
  echo "But: bypassing pre-push is a Hard-Stop violation per CLAUDE.md."
  exit 1
fi

# Canonical-identity guard: reject any pushed commit whose author email is not the
# fleet identity (Jobi0202 <tomorrow.tech.lab@gmail.com>). Reads the pre-push
# payload from stdin and judges only the commits being introduced.
# See scripts/check-author.mjs.
node "$(git rev-parse --show-toplevel)/scripts/check-author.mjs"
