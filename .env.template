# Central Secrets File for the Side-Hustle Pipeline
# Copy this to %USERPROFILE%\.sidehustle-secrets.env (Windows) or ~/.sidehustle-secrets.env (WSL/Linux)
# Fill in the real values. Builder reads from this file via `gh secret set --env-file` for every new repo.
# DO NOT commit the actual filled file. Only this template lives in the repo.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional — notify-jo.yml degrades gracefully if missing
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...
PUSHOVER_APP_TOKEN=...
PUSHOVER_USER_KEY=...
