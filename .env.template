# Central Secrets File for the Side-Hustle Pipeline
# Copy this to %USERPROFILE%\.sidehustle-secrets.env (Windows) or ~/.sidehustle-secrets.env (WSL/Linux).
# Fill in real values. Builder reads via `gh secret set --env-file` for every new repo.
# To rotate a key across ALL repos: edit a value here, then run scripts/set-secrets-all-repos.sh.
# DO NOT commit the filled file — only this template lives in the repo (see .gitignore).

# Required — Gate-2 reviewer (Claude OR DeepSeek backend) needs at least one of these.
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...

# Required — Gate-3 adversarial reviewer (Codex plugin).
OPENAI_API_KEY=sk-...

# Optional — notify-jo.yml degrades gracefully if missing.
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...
PUSHOVER_APP_TOKEN=...
PUSHOVER_USER_KEY=...
